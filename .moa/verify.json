{
  "checks": [
    {
      "name": "build",
      "command": "go build ./...",
      "timeout": "5m"
    },
    {
      "name": "vet",
      "command": "go vet ./...",
      "timeout": "5m"
    },
    {
      "name": "test",
      "command": "bash .moa/test-retry.sh",
      "timeout": "15m"
    },
    {
      "name": "lint",
      "command": "PATH=\"$PATH:$(go env GOPATH)/bin\" golangci-lint run --new-from-rev=c8539f5 ./...",
      "timeout": "5m"
    }
  ]
}
